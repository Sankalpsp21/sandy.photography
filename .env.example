# Supabase (get from app.supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudinary (get from console.cloudinary.com → Settings → Access Keys)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# --- Supabase Edge Function Secrets (set via Supabase CLI or Dashboard) ---
# These are NOT Vite env vars — set them as Edge Function secrets only
# supabase secrets set CLOUDINARY_API_SECRET=your-api-secret
# supabase secrets set CLOUDINARY_API_KEY=your-api-key
# supabase secrets set CLOUDINARY_CLOUD_NAME=your-cloud-name
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
